<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_gradient"
    android:padding="20dp">

    <!-- ================= GUEST ================= -->
    <LinearLayout
        android:id="@+id/layoutGuest"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginTop="40dp">

            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/ic_user"
                android:background="@drawable/bg_avatar_circle"
                android:padding="20dp"
                android:elevation="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chưa đăng nhập"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#EEEEEE"
                android:layout_marginTop="10dp"/>
        </LinearLayout>

        <!-- CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:background="@drawable/bg_card_dark"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tài khoản"
                android:textColor="#FFFFFF"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vui lòng đăng nhập"
                android:textColor="#CCCCCC"
                android:layout_marginBottom="10dp"/>

            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Đăng nhập"
                android:textColor="#FFFFFF"
                android:background="@drawable/btn_gradient"/>

            <Button
                android:id="@+id/btnRegister"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Đăng ký"
                android:textColor="#FFFFFF"
                android:layout_marginTop="10dp"
                android:background="@drawable/btn_gradient"/>

            <Button
                android:id="@+id/btnGuest"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Guest"
                android:textColor="#FFFFFF"
                android:layout_marginTop="10dp"
                android:background="@drawable/btn_gradient"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ================= LOGGED ================= -->
    <LinearLayout
        android:id="@+id/layout_profile_logged"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- HEADER -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:background="@drawable/bg_card_glass">

            <!-- Avatar -->
            <ImageView
                android:id="@+id/imgAvatar"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:src="@drawable/ic_user"
                android:background="@drawable/bg_avatar_circle"
                android:padding="12dp"/>

            <!-- Name -->
            <TextView
                android:id="@+id/txtName"
                android:layout_toRightOf="@id/imgAvatar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Tên user"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginTop="8dp"/>
            <TextView
                android:id="@+id/txtRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User"
                android:textSize="14sp"
                android:textColor="#BBBBBB"
                android:layout_marginTop="4dp"/>

            <!-- Premium -->
            <LinearLayout
                android:id="@+id/btnPremium"
                android:layout_below="@id/txtName"
                android:layout_toRightOf="@id/imgAvatar"
                android:layout_marginStart="12dp"
                android:layout_marginTop="6dp"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="10dp"
                android:background="@drawable/btn_premium">

                <TextView
                    android:text="Nâng cấp Premium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFD700"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

                <TextView
                    android:text=" >"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFD700"/>
            </LinearLayout>

            <!-- Logout (góc phải) -->
            <LinearLayout
                android:id="@+id/btnLogout"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/btn_logout"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/btn_logout"
                    app:tint="#FF6B6B"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đăng xuất"
                    android:textColor="#FF6B6B"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginStart="6dp"/>
            </LinearLayout>
        </RelativeLayout>

        <!-- ===== OPTIONS (TRONG SUỐT) ===== -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp">

            <View style="@style/optionItem"/>
            <View style="@style/optionItem"/>
            <View style="@style/optionItem"/>
            <View style="@style/optionItem"/>
            <View style="@style/optionItem"/>

        </LinearLayout>

    </LinearLayout>
</LinearLayout>